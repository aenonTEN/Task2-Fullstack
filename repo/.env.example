FRONTEND_PORT=4200
API_PORT=8080
DB_PORT=3306
DB_NAME=eaglepoint
DB_ROOT_PASSWORD=root
DB_DSN=root:root@tcp(db:3306)/eaglepoint?parseTime=true

# Security Configuration (optional - defaults used if not set)
# BCRYPT_COST=10                    # Password hashing cost (4-31, default: 10)
# TOKEN_TTL_HOURS=8             # Session token TTL in hours (default: 8)
# AES_KEY_HEX=                 # AES-256 key for data encryption (32 bytes = 64 hex chars)